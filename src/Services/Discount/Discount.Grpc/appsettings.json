{
  "ConnectionStrings": {
    "Database": "Data Source=discountdb"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    }
  },
  "ElasticConfiguration":{
    "Uri": "http://localhost:9200"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5002",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:6002",
        "Protocols": "Http2"
      }
    }
  }
}
